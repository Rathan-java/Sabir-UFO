# ===========================================
# Sabir UFO — Sighting Platform — Environment
# ===========================================
# Copy this file to `web/.env` (Vite reads it from there).
# All keys MUST be prefixed with VITE_ to be exposed to the bundle.

# ---- Firebase Web Config ----
# Get these from Firebase Console → Project Settings → "Your apps" → Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ---- Admin Identity ----
# The Google email that gets admin role on first login.
VITE_ADMIN_EMAIL=admin@example.com

# ---- WhatsApp eBook Lead ----
# International format, digits only, no +, no spaces (e.g. 919876543210)
VITE_ADMIN_WHATSAPP=919876543210

# ---- Media Provider ----
# "cloudinary" (free, recommended on Spark) or "firebase" (needs Blaze plan)
VITE_MEDIA_PROVIDER=cloudinary

# ---- Cloudinary (free unsigned upload) ----
# Create an unsigned upload preset at cloudinary.com/console → Settings → Upload
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=sabir_ufo_unsigned

# ---- Demo Mode ----
# When true, the app uses mock data so it runs without any Firebase keys.
# Set to false once your Firebase config is filled in above.
VITE_DEMO_MODE=true
